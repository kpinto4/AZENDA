# Copia a api/.env O crea .env en la RAIZ del monorepo (AZENDA/.env).
# Si existen los dos, api/.env gana en claves repetidas. Nada se sube a git (.gitignore).

# --- Neon (recomendado si no quieres Postgres local) ---
# La linea NO puede ir con # delante o el API no la lee. Pega la URL del panel Neon:
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Si usas DATABASE_URL, no hace falta PGHOST/PGPORT/PGUSER/PGPASSWORD para el API.
# Tras crear el proyecto en Neon: desde la raiz del repo ejecuta  npm run db:bootstrap
# (carga api/.env y crea tablas + datos demo en esa base).

# --- Solo si insistes en Postgres en esta maquina (sin Neon) ---
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=azenda

# --- SQLite local (no usa Neon ni Postgres) ---
# USE_SQLITE=1

# --- ngrok (opcional) ---
# NGROK_AUTHTOKEN=tu_token_ngrok
